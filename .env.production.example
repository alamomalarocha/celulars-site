# Common CELULARS platform configuration. Never commit real secrets.
PLATFORM_ENVIRONMENT=PRODUCTION
PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=443
PLATFORM_DATABASE_DRIVER=external
PLATFORM_DATABASE_URL=${PRODUCTION_DATABASE_URL}
PLATFORM_SESSION_SECRET=replace-with-a-random-secret-of-at-least-32-characters
PLATFORM_SESSION_COOKIE_NAME=celulars_platform_production_session
PLATFORM_SESSION_TTL_MINUTES=480
PLATFORM_SESSION_ROTATION_MINUTES=30
PLATFORM_ALLOWED_ORIGIN=https://platform.example.invalid
PLATFORM_PUBLIC_URL=https://platform.example.invalid
PLATFORM_SECURE_COOKIES=1
PLATFORM_STORAGE_MODE=external
PLATFORM_STORAGE_PATH=apps/platform/data/storage-production
PLATFORM_EMAIL_MODE=disabled
PLATFORM_WHATSAPP_MODE=disabled
PLATFORM_LOG_PATH=apps/platform/data/logs-production
PLATFORM_FEATURE_PUBLIC=false
PLATFORM_FEATURE_WHOLESALE_LOGIN=true
PLATFORM_FEATURE_EMPLOYEE_LOGIN=true
PLATFORM_FEATURE_EXTERNAL_MESSAGES=false
PLATFORM_FEATURE_REAL_EMAIL=false
PLATFORM_FEATURE_REAL_WHATSAPP=false
PLATFORM_FEATURE_DOCUMENTS=true
PLATFORM_FEATURE_MFA=false
PLATFORM_FEATURE_REPORTS=true
PLATFORM_FEATURE_RETURNS=true
PLATFORM_FEATURE_IMPORTS=false
PLATFORM_FEATURE_INTEGRATIONS=false
PLATFORM_DEMO_PASSWORD=